# This file contains all the environment variables needed by the application.
# Copy this file to .env and fill in the values.

# The URL of your database. For local development, SQLite is used.
DATABASE_URL="file:./dev.db"

# A secret key for NextAuth.js to encrypt JWTs and other sensitive data.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=""

# Cloudinary credentials for image uploads
# Get these from your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# These need to be exposed to the client for the uploader component.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_API_KEY=""

# A secret to protect the cron job endpoint from unauthorized access.
# Can be any long, random string.
CRON_SECRET=""
